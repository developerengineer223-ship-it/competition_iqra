import pandas as pd
df = pd.read_csv("students.csv")
print(df)
# print(df.info())
df.head() # by default, it will show the first 5 rows of the DataFrame.
df.tail() # by default, it will show the last 5 rows of the DataFrame.
df.rename(columns={"full_name": "Name"}, inplace=True) # Renaming the column "full_name" to "Name".
df.isna() # to check for missing values in the DataFrame, gives true/false for each cell.
df.isna().sum()# to get the count of missing/null values in each column.


