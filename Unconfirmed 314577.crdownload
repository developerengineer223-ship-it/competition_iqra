results = df["remarks"].dropna() # this only prints the remarks column and not the whole dataframe, and dropna() is used to remove the null values from the remarks column.
# print(results)
# print(df.dropna(subset=["remarks"])) # (for column basis) this will drop the rows where the remarks column has null values, and gives the whole dataframe.
# print(df.dropna(axis=0)) # (for row basis) this will drop the rows where any column has null values, and gives the whole dataframe.
print(df.drop(["hostel"], axis=1)) # (axis=0, row)(axis=1, column) this will drop the hostel column from the dataframe, and gives the whole dataframe without the hostel column.

df["age"].max() # to get the maximum age from the age column.
df["age"].min() # to get the minimum age from the age column.


