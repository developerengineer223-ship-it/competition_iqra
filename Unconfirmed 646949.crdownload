a=13
b=2
# Arithematic operators
print(a+b)
print(a-b)
print(a*b)
print(a/b)
print(a//b)
print(a**b)

# Relational operators
print(a>b)
print(a<b)
print(a<=b)
print(a>=b)
print(a==b)
print(a!=b)

# Logical operators 
print(a>b and a<b)
print(a<b or a>b)
print(not(a>b and a<b))

# Bitwise operators
print(5&6)
print(5|6)
print(5^6)
print(~5)
print(15>>1)
print(15<<1)

#Special operators

